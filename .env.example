# Example environment variables for the project
# Copy this file to .env and fill values before running the app

# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: sqlite)
DB_ENGINE=django.db.backends.sqlite3
# For Postgres, uncomment and set:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=bachelor_ghor
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# Redis (for Celery, optional)
REDIS_URL=redis://localhost:6379/0

# JWT / SimpleJWT
JWT_SECRET_KEY=change-me
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Notes:
# - Copy this file to `.env` at the repo root.
# - Keep `.env` out of version control and secure secrets for production.